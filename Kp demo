var SI_GRID = [[11,0,1,2],[10,-1,-1,3],[9,-1,-1,4],[8,7,6,5]];

function KPChart(props) {
  var positions = props.positions;
  var lagna     = props.lagna;
  var cusps     = props.cusps;
  var name      = props.name;
  var mode      = props.mode;
  var isTA      = props.lang === "ta";
  var sh = function(i){ return isTA ? PL_STA[i] : PL_SEN[i]; };

  var BCLR  = "1px solid #2a2a4a";
  var CH_PX = 130;
  // South Indian fixed grid: absolute rasi indices clockwise from top-left
  // PI AR TA GE
  // AQ -- -- CA
  // CP -- -- LE
  // SA SC LI VI
  var FLAT = [11,0,1,2, 10,-1,-1,3, 9,-1,-1,4, 8,7,6,5];

  var lagRi = lagna.ri;

  // Equal house: house number = position relative to lagna rasi (always sequential)
  // rasi at lagRi = H1, next rasi = H2, etc.
  function rasiToHouse(ri) { return ((ri - lagRi + 12) % 12) + 1; }

  // Build cusp degree map: house -> sidDeg from Equal house cusps
  // Used to display the actual cusp degree inside each box
  var cuspDegMap = {};
  cusps.forEach(function(cusp) {
    var hn = (mode === "kp249")
      ? ((cusp.ri - lagRi + 12) % 12) + 1
      : cusp.house;
    cuspDegMap[hn] = cusp.sidDeg;
  });

  // Planet map: rasi -> planets
  var pm = {};
  // Lagna marker
  if (!pm[lagRi]) pm[lagRi] = [];
  pm[lagRi].unshift({ label: isTA?"லக்":"Lag", deg: lagna.sidDeg, nl: sh(lagna.nl), subl: sh(lagna.subl), color:"#44ff88" });
  // All planets including Uranus, Neptune, Pluto
  positions.forEach(function(p, pi) {
    if (!pm[p.ri]) pm[p.ri] = [];
    pm[p.ri].push({ label: sh(pi), deg: p.sidDeg, nl: sh(p.nl), subl: sh(p.subl), color: PL_CLR[pi] });
  });

  // Format degree as "DD.MM.SS" like reference
  function fmtDeg(deg) {
    var inSign = deg % 30;
    var D = Math.floor(inSign);
    var mf = (inSign - D) * 60;
    var M = Math.floor(mf);
    var S = Math.floor((mf - M) * 60);
    return D + "." + String(M).padStart(2,"0") + "." + String(S).padStart(2,"0");
  }

  var cells = [];
  for (var r = 0; r < 4; r++) {
    for (var col = 0; col < 4; col++) {
      var rasi = FLAT[r*4+col];
      var isCenter = (rasi === -1);
      if (isCenter && !(r===1 && col===1)) continue;

      var borderRight  = col < 3 ? BCLR : "none";
      var borderBottom = r < 3 ? BCLR : "none";

      if (isCenter) {
        cells.push(ce("div", {
          key:"center",
          style:{
            gridColumn:"2 / 4", gridRow:"2 / 4",
            background:"#0a0a1a",
            borderRight:BCLR, borderBottom:"none", borderLeft:"none", borderTop:"none",
            display:"flex", flexDirection:"column", alignItems:"center", justifyContent:"center",
            padding:"4px", boxSizing:"border-box"
          }
        },
          ce("div",{style:{color:"#c8962a",fontSize:"13px",fontWeight:800,letterSpacing:"1px",marginBottom:"3px",textAlign:"center"}},
            isTA?"KP ஜாதகம்":"KP Chart"),
          ce("div",{style:{color:"#e8b84a",fontSize:"11px",fontWeight:600,textAlign:"center",maxWidth:"90%",wordBreak:"break-word"}},
            name||"")
        ));
      } else {
        var houseNum = rasiToHouse(rasi);
        var planets  = pm[rasi] || [];
        var cDeg     = cuspDegMap[houseNum];

        cells.push(ce("div", {
          key:r+"-"+col,
          style:{
            height:CH_PX+"px",
            borderRight:borderRight, borderBottom:borderBottom,
            borderLeft:"none", borderTop:"none",
            background:"#111128",
            position:"relative", overflow:"hidden",
            boxSizing:"border-box", padding:"3px 4px"
          }
        },
          // Top row: roman house number + cusp degree (top-left), like reference
          ce("div",{style:{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:"2px"}},
            ce("span",{style:{fontSize:"9px",color:"#585878",fontFamily:"monospace",fontWeight:700,lineHeight:1.3}},
              toRoman(houseNum) + (cDeg !== undefined ? " " + fmtDeg(cDeg) : "")
            )
          ),
          // Planets: "Ve Su Me" on line 1, degree on line 2
          ce("div",{style:{display:"flex",flexDirection:"column",gap:"2px"}},
            planets.map(function(p,i){
              return ce("div",{key:i, style:{marginBottom:"1px"}},
                ce("div",{style:{display:"flex",gap:"3px",alignItems:"baseline",lineHeight:1.3}},
                  ce("span",{style:{color:p.color,fontWeight:700,fontSize:"11px",fontFamily:"monospace",minWidth:"18px"}},
                    p.label),
                  p.nl   && ce("span",{style:{color:"#4488ee",fontSize:"9px",fontFamily:"monospace"}}, p.nl),
                  p.subl && ce("span",{style:{color:"#ffaa44",fontSize:"9px",fontFamily:"monospace"}}, p.subl)
                ),
                ce("div",{style:{color:"#e8b84a",fontSize:"9px",fontFamily:"monospace",lineHeight:1.2,paddingLeft:"2px"}},
                  fmtDeg(p.deg))
              );
            })
          )
        ));
      }
    }
  }

  return ce("div",{
    style:{
      display:"grid",
      gridTemplateColumns:"25% 25% 25% 25%",
      gridTemplateRows:CH_PX+"px "+CH_PX+"px "+CH_PX+"px "+CH_PX+"px",
      width:"100%",
      border:"2px solid #c8962a",
      borderRadius:"4px",
      overflow:"hidden",
      background:"#0a0a1a",
      boxShadow:"0 4px 20px rgba(0,0,0,.7)",
      boxSizing:"border-box"
    }
  }, cells);
}

