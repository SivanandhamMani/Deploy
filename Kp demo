  if (/long.*travel|long.*journey|தூர.*பயண/.test(t)) return "longtour";
  if (/travel|trip|journey|பயண/.test(t)) return "travel";
  if (/win|victory|court|case|lawsuit|legal|வெற்றி|வழக்கு|நீதி/.test(t)) return "selfwin";
  if (/income|wealth|money|earn|சம்பளம்|வரவு|வருமான|செல்வம்/.test(t)) return "income";
  if (/loan|debt|borrow|கடன்/.test(t)) return "loan";
  if (/promot|increment|raise|பதவி உயர்வு|ஊதிய/.test(t)) return "promotion";
  if (/lost|missing|misplaced|where.*item|find.*item|find.*object|find.*thing|தொலை|காணாமல்|கண்டுபிடி|எங்கே.*பொருள்|பொருள்.*எங்கே/.test(t)) return "lostitem";
  return null;
}

