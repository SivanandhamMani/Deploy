const VIM_ORDER = [8,5,0,1,2,7,4,6,3];
const SUBLORDS = (function() {
  var r = [];
  for (var n = 0; n < 27; n++) {
    var lord = NK[n][2];
    var startIdx = VIM_ORDER.indexOf(lord);
    var cum = 0; var s = [];
    for (var i = 0; i < 9; i++) {
      var p = VIM_ORDER[(startIdx+i)%9];
      var sm = (DASA[p]/120)*800;
      s.push({p:p, s:cum, e:cum+sm});
      cum += sm;
    }
    r.push(s);
  }
  return r;
})();

const KP249 = (function() {
  var out = []; var num = 1;
  for (var ni = 0; ni < 27; ni++) {
    var subs = SUBLORDS[ni];
    for (var si = 0; si < subs.length; si++) {
      if (num > 249) break;
      var a0 = ni*800 + subs[si].s;
      var a1 = ni*800 + subs[si].e;
      var sg0 = Math.floor(a0/1800)%12;
      var sg1 = Math.floor((a1-0.001)/1800)%12;
      if (sg0 === sg1) {
        out.push({n:num++, sg:sg0, sl:RS_LORD[sg0], nk:ni, nl:NK[ni][2], sub:si+1, subl:subs[si].p, d0:a0/60, d1:a1/60});
      } else {
        var boundary = (sg0+1)*1800;
        out.push({n:num++, sg:sg0, sl:RS_LORD[sg0], nk:ni, nl:NK[ni][2], sub:si+1, subl:subs[si].p, d0:a0/60, d1:boundary/60});
        if (num <= 249)
          out.push({n:num++, sg:sg1, sl:RS_LORD[sg1], nk:ni, nl:NK[ni][2], sub:si+1, subl:subs[si].p, d0:boundary/60, d1:a1/60});
      }
    }
  }
  return out;
})();

function getKP(sid) {
  var d = norm(sid);
  var ri = Math.floor(d/30)%12;
  var tot = d*60;
  var ni = Math.min(Math.floor(tot/800), 26);
  var mn = tot - ni*800;
  var subs = SUBLORDS[ni];
  var si = subs.length-1;
  for (var k = 0; k < subs.length; k++) { if (mn < subs[k].e - 1e-6) { si = k; break; } }
  return { ri:ri, ni:ni, sl:RS_LORD[ri], nl:NK[ni][2], subl:subs[si].p };
}

function fmtAbs(d) {
  var dd = norm(d);
  var inSign = dd % 30;
  var D = Math.floor(inSign), rem = (inSign-D)*60, M = Math.floor(rem), S = Math.round((rem-M)*60);
  if(S===60){S=0;M++;} if(M===60){M=0;D++;}
  return String(D).padStart(2,'0')+" "+String(M).padStart(2,'0')+"'"+String(S).padStart(2,'0')+'"';
}
function fmtDMS(d) {
  var inSign = d%30, D = Math.floor(inSign), rem = (inSign-D)*60, M = Math.floor(rem), S = Math.round((rem-M)*60);
  return String(D).padStart(2,'0')+" "+String(M).padStart(2,'0')+"'"+String(S).padStart(2,'0')+'"';
}
function fmtSign(d) {
