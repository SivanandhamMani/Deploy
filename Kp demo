// Get all planets influencing a planet (aspects + conjunctions)
function getPlanetInfluences(pl, positions) {
  var pos = positions.find(function(p){ return p.pl === pl; });
  if (!pos) return [];
  var influences = new Set();
  positions.forEach(function(p) {
    if (p.pl > 8 || p.pl === pl) return;
    // Conjunction
    if (withinOrb(p.sidDeg, pos.sidDeg)) { influences.add(p.pl); return; }
    // Aspects
    var aspDegrees = getPlanetAspects(p.pl, p.sidDeg);
    aspDegrees.forEach(function(aspDeg) {
      if (withinOrb(aspDeg, pos.sidDeg)) influences.add(p.pl);
    });
  });
  return Array.from(influences);
}

// Get L1/L2/L3/L4 significators for a specific house
function getHouseSigs(houseNum, positions, cusps, lagnaRi) {
  var L1=[],L2=[],L3=[],L4=[];

  // KP correct method: use CUSP BOUNDARIES to find house occupants
  // A planet is in a house if its sidDeg falls between that house cusp
  // and the next house cusp (handling 360 wraparound)
  var cuspStart = cusps[houseNum-1] ? cusps[houseNum-1].sidDeg : (lagnaRi*30 + (houseNum-1)*30) % 360;
  var cuspEnd   = cusps[houseNum%12] ? cusps[houseNum%12].sidDeg : (cuspStart+30) % 360;

  function isBetweenCusps(deg) {
    if (cuspStart <= cuspEnd) return deg >= cuspStart && deg < cuspEnd;
    // Wraparound: e.g. cusp at 350, next at 20
    return deg >= cuspStart || deg < cuspEnd;
  }

  // L2: planets whose sidereal degree falls inside this house (between cusps)
  positions.forEach(function(p){
    if(p.pl>8) return;
    if(isBetweenCusps(p.sidDeg)) L2.push(p.pl);
  });

  // L1: planets in the star of any L2 occupant (strongest significator)
  L2.forEach(function(occ){
    positions.forEach(function(p){
      if(p.pl>8) return;
      if(p.nl === occ && L1.indexOf(p.pl)===-1) L1.push(p.pl);
    });
  });

  // L4: sign lord of the rasi where this house CUSP falls
  var houseRi = cusps[houseNum-1] ? cusps[houseNum-1].ri : (lagnaRi + houseNum - 1) % 12;
  var lord = RS_LORD[houseRi];
  if(lord<=8) L4.push(lord);

  // L3: planets in the star of the house owner (L4)
  L4.forEach(function(own){
    positions.forEach(function(p){
      if(p.pl>8) return;
      if(p.nl === own && L3.indexOf(p.pl)===-1) L3.push(p.pl);
    });
  });

  return {L1:L1,L2:L2,L3:L3,L4:L4};
}

// Get combined significators for multiple houses with priority order
function getCombinedSigs(houses, positions, cusps, lagnaRi) {
  var allL1=[],allL2=[],allL3=[],allL4=[];
  houses.forEach(function(h){
    var s=getHouseSigs(h,positions,cusps,lagnaRi);
    s.L1.forEach(function(p){if(allL1.indexOf(p)===-1)allL1.push(p);});
    s.L2.forEach(function(p){if(allL2.indexOf(p)===-1)allL2.push(p);});
    s.L3.forEach(function(p){if(allL3.indexOf(p)===-1)allL3.push(p);});
    s.L4.forEach(function(p){if(allL4.indexOf(p)===-1)allL4.push(p);});
  });
  // Return in priority order L1>L2>L3>L4, deduplicated
  var seen=new Set(), result=[];
  [allL1,allL2,allL3,allL4].forEach(function(layer,li){
    layer.forEach(function(p){
      if(!seen.has(p)){seen.add(p);result.push({pl:p,layer:li+1});}
    });
  });
  return result; // [{pl, layer}]
}

