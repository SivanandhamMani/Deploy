  // Lagna from KP number; planets + cusps + everything else from gocharaData (Gochara)
  var entry = KP249[n-1];
  if (!entry) return null;
  var lagDeg = entry.d0;
  var lagKP  = getKP(lagDeg);
  var lagna  = { tropDeg:lagDeg, sidDeg:lagDeg, ri:Math.floor(lagDeg/30)%12,
                 sl:lagKP.sl, nl:lagKP.nl, subl:lagKP.subl };

  // Planets from Gochara - unchanged
  var positions = gocharaData ? gocharaData.positions : [];
  // Build exactly 12 cusps in KP lagna order (House I = KP lagna rasi, going around)
  // For each house, find the matching Gochara cusp by rasi; fallback to equal house
  var lagRi = Math.floor(lagDeg/30)%12;
  var rawCusps = gocharaData ? gocharaData.cusps : [];
  // Build a map: rasi -> gochara cusp
  var goCuspByRasi = {};
  rawCusps.forEach(function(c){ goCuspByRasi[c.ri] = c; });
  var cusps = [];
  for (var hi = 0; hi < 12; hi++) {
    var houseRi = (lagRi + hi) % 12;
    var houseNum = hi + 1;
    if (hi === 0) {
      // House I always = KP number lagna degree
      cusps.push({ house:houseNum, d:lagDeg, sidDeg:lagDeg, ri:lagRi,
                   sl:lagKP.sl, nl:lagKP.nl, subl:lagKP.subl });
    } else if (goCuspByRasi[houseRi]) {
      // Use Gochara cusp for this rasi, relabelled with KP house number
      var gc = goCuspByRasi[houseRi];
      cusps.push(Object.assign({}, gc, { house:houseNum }));
    } else {
      // Fallback: equal house from KP lagna
      var eqDeg = (lagDeg + hi*30) % 360;
      var eqKP  = getKP(eqDeg);
      cusps.push({ house:houseNum, d:eqDeg, sidDeg:eqDeg, ri:houseRi,
                   sl:eqKP.sl, nl:eqKP.nl, subl:eqKP.subl });
    }
  }

  var moonDeg = positions.length > 0 ? positions[1].sidDeg : lagDeg;
  var sunDeg  = positions.length > 0 ? positions[0].sidDeg : lagDeg;
  var panchang    = calcPanchang(sunDeg, moonDeg);
  var dasaBalance = positions.length > 0
    ? calcDasaBalance(positions[1])
    : { planet:lagKP.nl, years:0, months:0, days:0 };
  var significators = calcSignificators(positions, lagna);
  var ruling = gocharaData ? Object.assign({}, gocharaData.ruling, {
    lagnaSignLord:lagna.sl, lagnaStarLord:lagna.nl, lagnaSubLord:lagna.subl
  }) : {
    dayLord:0, lagnaSignLord:lagna.sl, lagnaStarLord:lagna.nl, lagnaSubLord:lagna.subl,
    moonSignLord:lagna.sl, moonStarLord:lagna.nl, moonSubLord:lagna.subl
  };
  var inp = gocharaData
    ? Object.assign({}, gocharaData.input, {name:"KP #"+n})
    : { name:"KP #"+n, day:1, month:1, year:2000, hour:0, minute:0, second:0,
        lat:0, lon:0, place:"KP Number "+n, gender:"male" };

  return {
    positions:positions, lagna:lagna, cusps:cusps, panchang:panchang,
    dasaBalance:dasaBalance, significators:significators, ruling:ruling,
    T:    gocharaData ? gocharaData.T    : 0,
    ayan: gocharaData ? gocharaData.ayan : 0,
    input:inp, mode:"kp249", kpNum:n, kpEntry:entry
  };
}

function calcGocharaFull(yr, mo, dy, utHr, lat, lon) {
  var jd  = julianDay(yr, mo, dy, utHr);
  var T   = (jd - 2451545.0) / 36525.0;
  var ayan = lahiriAyanamsa(T);
  var earth   = earthHelio(T);
  var mercury = planetHelio(0.38709927,0.20563593, 0.00001906,252.25032350,149472.67411175, 77.45779628, 0.16047689,T);
  var venus   = planetHelio(0.72333566,0.00677672,-0.00004107,181.97909950, 58517.81538729,131.60246718, 0.00268329,T);
  var mars    = planetHelio(1.52371034,0.09339410, 0.00007882,355.44656122, 19140.30268499,336.05637041, 0.44441088,T);
  var jupiter = planetHelio(5.20288700,0.04838624,-0.00013253, 34.39644051,  3034.74612775, 14.72847983, 0.21252668,T);
  var saturn  = planetHelio(9.53667594,0.05386179,-0.00050991, 49.95424423, 1222.49514316, 92.59887831,-0.41897216,T);
  var uranus  = calcUranus(T); var neptune = calcNeptune(T); var pluto = calcPluto(T);
  var sunTrop  = calcSun(T);
  var moonTrop = calcMoon(T);
  var rahuTrop = calcRahu(T);
  var ketuTrop = norm(rahuTrop + 180);
  var trops = [sunTrop, moonTrop,
    geoLon(mars.x,mars.y,earth.x,earth.y), geoLon(mercury.x,mercury.y,earth.x,earth.y),
    geoLon(jupiter.x,jupiter.y,earth.x,earth.y), geoLon(venus.x,venus.y,earth.x,earth.y),
    geoLon(saturn.x,saturn.y,earth.x,earth.y), rahuTrop, ketuTrop,
    geoLon(uranus.x,uranus.y,earth.x,earth.y), geoLon(neptune.x,neptune.y,earth.x,earth.y),
    geoLon(pluto.x,pluto.y,earth.x,earth.y)];
  var positions = trops.map(function(t,i){ var sid=norm(t-ayan); return Object.assign({pl:i,tropDeg:t,sidDeg:sid,ayan:ayan},getKP(sid)); });
  // Retrograde detection
  var T1gf = T - 1/365.25;
  var earth1gf = earthHelio(T1gf);
  var trops1gf = [
    calcSun(T1gf), calcMoon(T1gf),
    geoLon(planetHelio(1.52371034,0.09339410,0.00007882,355.44656122,19140.30268499,336.05637041,0.44441088,T1gf).x,
           planetHelio(1.52371034,0.09339410,0.00007882,355.44656122,19140.30268499,336.05637041,0.44441088,T1gf).y,earth1gf.x,earth1gf.y),
    geoLon(planetHelio(0.38709927,0.20563593,0.00001906,252.25032350,149472.67411175,77.45779628,0.16047689,T1gf).x,
           planetHelio(0.38709927,0.20563593,0.00001906,252.25032350,149472.67411175,77.45779628,0.16047689,T1gf).y,earth1gf.x,earth1gf.y),
    geoLon(planetHelio(5.20288700,0.04838624,-0.00013253,34.39644051,3034.74612775,14.72847983,0.21252668,T1gf).x,
           planetHelio(5.20288700,0.04838624,-0.00013253,34.39644051,3034.74612775,14.72847983,0.21252668,T1gf).y,earth1gf.x,earth1gf.y),
    geoLon(planetHelio(0.72333566,0.00677672,-0.00004107,181.97909950,58517.81538729,131.60246718,0.00268329,T1gf).x,
           planetHelio(0.72333566,0.00677672,-0.00004107,181.97909950,58517.81538729,131.60246718,0.00268329,T1gf).y,earth1gf.x,earth1gf.y),
    geoLon(planetHelio(9.53667594,0.05386179,-0.00050991,49.95424423,1222.49514316,92.59887831,-0.41897216,T1gf).x,
           planetHelio(9.53667594,0.05386179,-0.00050991,49.95424423,1222.49514316,92.59887831,-0.41897216,T1gf).y,earth1gf.x,earth1gf.y),
    calcRahu(T1gf), norm(calcRahu(T1gf)+180)
  ];
  positions = positions.map(function(p, i) {
    if (i >= 9) return Object.assign({}, p, {retro: false});
    if (i === 7 || i === 8) return Object.assign({}, p, {retro: true});
    var diff = ((trops[i] - trops1gf[i] + 360) % 360);
    var motion = diff > 180 ? diff - 360 : diff;
    return Object.assign({}, p, {retro: motion < 0});
  });
  var lagna = calcAscendant(jd,T,lat,lon,ayan);
  // Equal house cusps (KP system)
  var cusps = calcHouseCusps(jd,T,lat,lon,ayan);
  var panchang    = calcPanchang(positions[0].sidDeg, positions[1].sidDeg);
  var dasaBalance = calcDasaBalance(positions[1]);
  var significators = calcSignificators(positions, lagna);
  var DAY_PL    = [0,1,2,3,4,5,6];
  var dayOfWeek = (function(){ var d=new Date(yr,mo-1,dy); return d.getDay(); })();
  var ruling = {
    dayLord: DAY_PL[dayOfWeek],
    lagnaSignLord: lagna.sl, lagnaStarLord: lagna.nl, lagnaSubLord: lagna.subl,
    moonSignLord: positions[1].sl, moonStarLord: positions[1].nl, moonSubLord: positions[1].subl
  };
  return {
    positions:positions, lagna:lagna, cusps:cusps, panchang:panchang,
    dasaBalance:dasaBalance, significators:significators, ruling:ruling,
    T:T, ayan:ayan,
    input:{ name:"Transit", day:dy, month:mo, year:yr,
            hour:Math.floor(utHr-5.5), minute:Math.floor(((utHr-5.5)%1)*60),
            second:0, lat:lat, lon:lon, place:"Transit Chart", gender:"male" },
    mode:"gochara"
  };
}

