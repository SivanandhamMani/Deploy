  const lst = norm(gmst+lon);
  const lr = toRad(lst), la = toRad(lat), er = toRad(eps);
  const ascTrop = norm(toDeg(Math.atan2(Math.cos(lr), -(Math.sin(lr)*Math.cos(er)+Math.tan(la)*Math.sin(er)))));
  const ascSid = norm(ascTrop-ayan);
  return { tropDeg:ascTrop, sidDeg:ascSid, ...getKP(ascSid) };
}

function calcHouseCusps(jd, T, lat, lon, ayan) {
  // KP system uses Porphyry house system:
  // Divide each quadrant (ASC->IC, IC->DSC, DSC->MC, MC->ASC) into 3 equal parts
  var eps  = 23.439291111 - 0.013004167*T;
  var gmst = norm(280.46061837 + 360.98564736629*(jd-2451545.0) + 0.000387933*T*T);
  var ramc = norm(gmst + lon);
  var ramcR = toRad(ramc), latR = toRad(lat), epsR = toRad(eps);

  // Tropical ASC
  var ascTrop = norm(toDeg(Math.atan2(
    Math.cos(ramcR),
    -(Math.sin(ramcR)*Math.cos(epsR) + Math.tan(latR)*Math.sin(epsR))
  )));

  // Tropical MC
  var mcTrop = norm(toDeg(Math.atan2(Math.tan(ramcR), Math.cos(epsR))));
  if (Math.cos(ramcR) < 0) mcTrop = norm(mcTrop + 180);

  // Sidereal angles
  var asc = norm(ascTrop - ayan);
  var mc  = norm(mcTrop  - ayan);
  var ic  = norm(mc  + 180);
  var dsc = norm(asc + 180);

  // Porphyry: divide each quadrant into 3 equal arcs
  // Arc going forward (counterclockwise) from start to end
  function arcFwd(start, end) { return norm(end - start); }

  var q1 = arcFwd(asc, ic);   // Q1: ASC -> IC  (H2,H3 inside)
  var q2 = arcFwd(ic,  dsc);  // Q2: IC  -> DSC (H5,H6 inside)
  var q3 = arcFwd(dsc, mc);   // Q3: DSC -> MC  (H8,H9 inside)
  var q4 = arcFwd(mc,  asc);  // Q4: MC  -> ASC (H11,H12 inside)

  var h2  = norm(asc + q1/3);
  var h3  = norm(asc + 2*q1/3);
  var h5  = norm(ic  + q2/3);
  var h6  = norm(ic  + 2*q2/3);
  var h8  = norm(dsc + q3/3);
  var h9  = norm(dsc + 2*q3/3);
  var h11 = norm(mc  + q4/3);
  var h12 = norm(mc  + 2*q4/3);

  var sidCusps = [asc, h2, h3, ic, h5, h6, dsc, h8, h9, mc, h11, h12];

  return sidCusps.map(function(sid, i) {
    return { house:i+1, d:sid, sidDeg:sid, ri:Math.floor(sid/30)%12, ...getKP(sid) };
  });
}

