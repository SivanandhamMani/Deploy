function GocharaGrid(props) {
  var gpPositions = props.positions;
  var gpLagna     = props.lagna;
  var gpCusps     = props.cusps || [];
  var gpIsTA      = props.lang === "ta";
  var gpSh        = function(i){ return gpIsTA ? PL_STA[i] : PL_SEN[i]; };
  var BCLR        = "1px solid #2a2a4a";
  var CH_PX       = 150;
  var FLAT        = [11,0,1,2, 10,-1,-1,3, 9,-1,-1,4, 8,7,6,5];
  var gpLagRi     = gpLagna.ri;

  function gpFmt(deg) {
    var s = deg % 30;
    var D = Math.floor(s);
    var mf = (s - D) * 60;
    var M = Math.floor(mf);
    var S = Math.floor((mf - M) * 60);
    return D + "." + String(M).padStart(2,"0") + "." + String(S).padStart(2,"0");
  }

  // Planet map: rasi -> array of planet objects
  var gpPM = {};
  if (!gpPM[gpLagRi]) gpPM[gpLagRi] = [];
  gpPM[gpLagRi].unshift({
    lbl: gpIsTA ? "லக்" : "Lag",
    deg: gpLagna.sidDeg,
    nl:  gpSh(gpLagna.nl),
    sub: gpSh(gpLagna.subl),
    clr: "#44ff88"
  });
  for (var gpi = 0; gpi < gpPositions.length; gpi++) {
    var gpp = gpPositions[gpi];
    if (!gpPM[gpp.ri]) gpPM[gpp.ri] = [];
    gpPM[gpp.ri].push({
      lbl: gpSh(gpp.pl),
      deg: gpp.sidDeg,
      nl:  gpSh(gpp.nl),
      sub: gpSh(gpp.subl),
      clr: PL_CLR[gpp.pl]
    });
  }

  // Cusp map: rasi -> array of cusp objects
  var gpCM = {};
  for (var gci = 0; gci < gpCusps.length; gci++) {
    var gcc = gpCusps[gci];
    if (!gpCM[gcc.ri]) gpCM[gcc.ri] = [];
    gpCM[gcc.ri].push(gcc);
  }

  var cells = [];
  for (var grow = 0; grow < 4; grow++) {
    for (var gcol = 0; gcol < 4; gcol++) {
      var grasi = FLAT[grow * 4 + gcol];
      var gIsCenter = (grasi === -1);
      if (gIsCenter && !(grow === 1 && gcol === 1)) continue;
      var gBR = gcol < 3 ? BCLR : "none";
      var gBB = grow < 3 ? BCLR : "none";

      if (gIsCenter) {
        cells.push(ce("div", {key:"center", style:{
          gridColumn:"2 / 4", gridRow:"2 / 4", background:"#0a0a1a",
          borderRight:BCLR, borderBottom:"none", borderLeft:"none", borderTop:"none",
          display:"flex", flexDirection:"column", alignItems:"center",
          justifyContent:"center", padding:"4px", boxSizing:"border-box"
        }},
          ce("div", {style:{color:"#55ddff",fontSize:"11px",fontWeight:800,textAlign:"center"}},
            gpIsTA ? "கோச்சார KP" : "Transit KP"),
          ce("div", {style:{color:"#44ff88",fontSize:"9px",textAlign:"center",marginTop:"3px"}},
            gpIsTA ? "தற்போதைய லக்னம்" : "Current Lagna"),
          ce("div", {style:{color:"#e8b84a",fontSize:"9px",textAlign:"center",marginTop:"2px"}},
            gpIsTA ? RS_TA[gpLagRi] : RS_EN[gpLagRi])
        ));
      } else {
        var gCellPl = gpPM[grasi] || [];
        var gCellCu = gpCM[grasi] || [];
        var gIsLag  = grasi === gpLagRi;

        cells.push(ce("div", {key: grow+"-"+gcol, style:{
          height: CH_PX+"px", borderRight:gBR, borderBottom:gBB,
          borderLeft:"none", borderTop:"none",
          background: gIsLag ? "#0d1a10" : "#111128",
          position:"relative", overflow:"hidden",
          boxSizing:"border-box", padding:"2px 3px"
        }},
          ce("div", {style:{fontSize:"8px", color: gIsLag?"#44ff88":"#484868",
            fontFamily:"monospace", fontWeight:700, lineHeight:1}},
            gpIsTA ? RS_TA[grasi].substring(0,3) : RS_SH[grasi]),
          gIsLag && ce("div", {style:{position:"absolute",top:"2px",right:"3px",
            fontSize:"8px",color:"#44ff88",fontWeight:700}},
            gpIsTA ? "லக்" : "Lag"),
          ce("div", {style:{marginTop:"2px"}},
            gCellPl.map(function(pp, ppi) {
              return ce("div", {key:ppi, style:{marginBottom:"1px"}},
                ce("div", {style:{display:"flex",gap:"3px",alignItems:"baseline",lineHeight:1.3}},
                  ce("span", {style:{color:pp.clr,fontWeight:700,fontSize:"11px",
                    fontFamily:"monospace",minWidth:"18px"}}, pp.lbl),
                  pp.nl  && ce("span", {style:{color:"#4488ee",fontSize:"9px",fontFamily:"monospace"}}, pp.nl),
                  pp.sub && ce("span", {style:{color:"#ffaa44",fontSize:"9px",fontFamily:"monospace"}}, pp.sub)
                ),
                ce("div", {style:{color:"#e8b84a",fontSize:"9px",fontFamily:"monospace",
                  lineHeight:1.2,paddingLeft:"2px"}}, gpFmt(pp.deg))
              );
            })
          ),
          gCellCu.length > 0 && ce("div", {style:{
            borderTop:"1px solid #252545", marginTop:"3px", paddingTop:"2px"
          }},
            gCellCu.map(function(hc, hci) {
              return ce("div", {key:hci, style:{fontSize:"9px",color:"#585878",
                fontFamily:"monospace",lineHeight:1.4}},
                toRoman(hc.house) + " " + fmtSign(hc.d)
              );
            })
          )
        ));
      }
    }
  }

  return ce("div", {style:{
    display:"grid",
    gridTemplateColumns:"25% 25% 25% 25%",
    gridTemplateRows: CH_PX+"px "+CH_PX+"px "+CH_PX+"px "+CH_PX+"px",
    width:"100%", border:"2px solid #55ddff", borderRadius:"4px",
    overflow:"hidden", background:"#0a0a1a",
    boxShadow:"0 4px 20px rgba(0,0,0,.7)", boxSizing:"border-box"
  }}, cells);
}







// KPLookup 
function KPLookup(props) {
  var lang=props.lang, isTA=lang==="ta", gData=props.gData||null;
  var _a=useState(""), num=_a[0], setNum=_a[1];
  var _b=useState(null), res=_b[0], setRes=_b[1];
  var C={gold:"#e8b84a",cyan:"#55ddff",green:"#44ff88",red:"#ff5566",grey:"#585878",purple:"#cc88ff"};

  function lookup(n) {
    n=parseInt(n,10);
    if(isNaN(n)||n<1||n>249){setRes(null);return;}
    var entry=KP249[n-1]; if(!entry){setRes(null);return;}
    // entry has: sg(rasi 0-11), nk(nakshatra idx), subl(sub lord planet idx), d0(start deg), d1(end deg)
    // Treat d0 as the "lagna degree" - build KP chart + cusp table from this degree
    var lagDeg = entry.d0; // absolute sidereal degree
    var lagRi = entry.sg;
    // Build 12 house cusps: equal house from lagna degree
    var cusps = [];
    for(var h=0;h<12;h++){
      var cDeg = (lagDeg + h*30) % 360;
      var cRi = Math.floor(cDeg/30)%12;
      var kp = getKP(cDeg);
      cusps.push({house:h+1, d:cDeg, ri:cRi, sl:kp.sl, nl:kp.nl, subl:kp.subl});
    }
    // Lagna object
    var lagKP = getKP(lagDeg);
    var lagna = {sidDeg:lagDeg, ri:lagRi, sl:lagKP.sl, nl:lagKP.nl, subl:lagKP.subl};
    setRes({n:n, entry:entry, lagna:lagna, cusps:cusps});
  }

  function randomPick() {
    var r=Math.floor(Math.random()*249)+1;
    setNum(String(r)); lookup(r);
  }

  var sh = function(i){ return isTA?PL_STA[i]:PL_SEN[i]; };

