  function analyze(topic) {
    if (!chartData) return;
    if (!chartData.positions || chartData.positions.length === 0) {
      setResult({empty:true,topic:topic}); return;
    }

    var positions = chartData.positions;
    var cusps = chartData.cusps;
    var lagna = chartData.lagna;
    var lagnaRi = lagna ? lagna.ri : 0;

    // -- CHILD INFERTILE CHECK ---------------------------------------------
    // Before analysing 2nd child: check if 1st child CSL rasi is infertile
    // Before analysing 3rd child: check 1st AND 2nd child CSL rasi
    if (topic.id === "child2" || topic.id === "child3") {
      // 1st child: 5th house CSL
      var firstChildCsl = cusps[4] ? cusps[4].subl : null;
      var firstChildRi = firstChildCsl !== null ? (positions.find(function(p){return p.pl===firstChildCsl;})||{ri:0}).ri : 0;
      if (INFERTILE_RASI.indexOf(firstChildRi) !== -1) {
        setResult({
          infertileBlock: true,
          topic: topic,
          blockedAt: "1st",
          blockedRasi: RS_EN[firstChildRi],
          msg: isTA ? "முதல் குழந்தை CSL மலட்டு ராசியில் உள்ளது (" + (isTA?RS_TA[firstChildRi]:RS_EN[firstChildRi]) + "). ஒரே ஒரு குழந்தை மட்டுமே சாத்தியம்." : "1st child CSL is in " + RS_EN[firstChildRi] + " (infertile rasi). Only 1 child possible. 2nd and 3rd child not indicated."
        });
        return;
      }
    }
    if (topic.id === "child3") {
      // 2nd child: 7th house CSL
      var secondChildCsl = cusps[6] ? cusps[6].subl : null;
      var secondChildRi = secondChildCsl !== null ? (positions.find(function(p){return p.pl===secondChildCsl;})||{ri:0}).ri : 0;
      if (INFERTILE_RASI.indexOf(secondChildRi) !== -1) {
        setResult({
          infertileBlock: true,
          topic: topic,
          blockedAt: "2nd",
          blockedRasi: RS_EN[secondChildRi],
          msg: isTA ? "இரண்டாம் குழந்தை CSL மலட்டு ராசியில் உள்ளது (" + (isTA?RS_TA[secondChildRi]:RS_EN[secondChildRi]) + "). இரண்டு குழந்தைகள் மட்டுமே. மூன்றாம் குழந்தை இல்லை." : "2nd child CSL is in " + RS_EN[secondChildRi] + " (infertile rasi). Only 2 children possible. 3rd child not indicated."
        });
        return;
      }
    }

    // Helper: get planet object
    function getPos(pl){ return positions.find(function(p){return p.pl===pl;}); }
    function getPl_sl(pl){ var p=getPos(pl); return p?p.sl:null; }
    function getPl_nl(pl){ var p=getPos(pl); return p?p.nl:null; }
    function getPl_subl(pl){ var p=getPos(pl); return p?p.subl:null; }
    function getPl_ri(pl){ var p=getPos(pl); return p?p.ri:0; }
    function getPl_sidDeg(pl){ var p=getPos(pl); return p?p.sidDeg:0; }

    // -- STEP 1: Find CSL of main house --------------------------------------
    var csl = cusps[topic.mainHouse-1] ? cusps[topic.mainHouse-1].subl : null;
    if (csl === null) { setResult({empty:true,topic:topic}); return; }

    // -- CONDITION 1: Will it happen? ----------------------------------------
    // CSL's star lord
    var cslStarLord = getPl_nl(csl);

    // Check if Rahu/Ketu - expand through absorption
    function expandRahuKetu(pl) {
      if (pl !== 7 && pl !== 8) return [pl];
      var conn = getRahuKetuConnections(pl, positions, cusps, lagnaRi);
      return [pl].concat(conn);
    }

    var starLordPlanets = expandRahuKetu(cslStarLord); // all planets to check for YES/NO

    // Get sigs for a planet (L1/L2/L3/L4 houses it signifies)
    function getPlanetAllSigs(pl) {
      var houses = [];
      for (var h=1; h<=12; h++) {
        var hs = getHouseSigs(h, positions, cusps, lagnaRi);
        var allInH = hs.L1.concat(hs.L2).concat(hs.L3).concat(hs.L4);
        if (allInH.indexOf(pl) !== -1) houses.push(h);
      }
      return houses;
    }

    // Check promise: star lord (expanded) signifies promise houses
    var promiseHouses = topic.promiseH;
    var cslStarSigs = [];
    starLordPlanets.forEach(function(pl){
      getPlanetAllSigs(pl).forEach(function(h){
        if(cslStarSigs.indexOf(h)===-1) cslStarSigs.push(h);
      });
    });
    var promiseHit = promiseHouses.filter(function(h){return cslStarSigs.indexOf(h)!==-1;});
    var hasPromise = promiseHit.length >= 1;

    // -- CONDITION 2: Characteristics ----------------------------------------
    // CSL rasi
    var cslRi = getPl_ri(csl);
    var cslRasi = RS_EN[cslRi];
    var cslElem = RASI_ELEM2_EN[cslRi];
    var cslType = RASI_TYPE_EN[cslRi]; // Movable/Fixed/Dual
    var cslGender = RASI_GENDER2_EN[cslRi];
    var cslCaste = RASI_CASTE_EN[cslRi];
    var cslDharma = RASI_DHARMA_EN[cslRi];
    var cslLegs = RASI_LEGS[cslRi];

    // CSL planet nature + all influencing planets (aspects + conjunctions)
    var cslInfluences = getPlanetInfluences(csl, positions);
    var cslAllPlanets = [csl].concat(cslInfluences); // CSL + all planets seeing/with CSL

    // CSL significations for characteristic description
    var cslSigs = getPlanetAllSigs(csl);

    // -- CONDITION 3: After result (post event life) --------------------------
    var cslSubLord = getPl_subl(csl);
    var cslSubSigs = cslSubLord !== null ? getPlanetAllSigs(cslSubLord) : [];
    // Expand if Rahu/Ketu
    if (cslSubLord === 7 || cslSubLord === 8) {
      var expSub = getRahuKetuConnections(cslSubLord, positions, cusps, lagnaRi);
      expSub.forEach(function(pl){
        getPlanetAllSigs(pl).forEach(function(h){
          if(cslSubSigs.indexOf(h)===-1) cslSubSigs.push(h);
        });
      });
    }
    // House quality scoring (love/material)
    // Inner 1,3,7,11: love=70, material=30
    // Outer 2,4,6,10: love=30, material=70
    // Special 5,9: love=100, material=0
    // Bad 8,12: negative
    var afterLoveScore=0, afterMatScore=0, afterBadCount=0, afterCount=0;
    cslSubSigs.forEach(function(h){
      if([1,3,7,11].indexOf(h)!==-1){afterLoveScore+=70;afterMatScore+=30;afterCount++;}
      else if([2,4,6,10].indexOf(h)!==-1){afterLoveScore+=30;afterMatScore+=70;afterCount++;}
      else if([5,9].indexOf(h)!==-1){afterLoveScore+=100;afterMatScore+=0;afterCount++;}
      else if([8,12].indexOf(h)!==-1){afterBadCount++;afterCount++;}
      else if(h===6){afterBadCount++;afterCount++;}
    });
    var afterLoveAvg = afterCount>0?Math.round(afterLoveScore/afterCount):0;
    var afterMatAvg = afterCount>0?Math.round(afterMatScore/afterCount):0;
    var afterOutcome = afterBadCount > afterCount/2 ? "troubled" : afterLoveAvg>=60?"loving":"balanced";

    // -- STEP 6: TIMING -------------------------------------------------------
    // Get all planets connected to promise houses L1/L2/L3/L4
    var houseSigsFull = getCombinedSigs(promiseHouses, positions, cusps, lagnaRi);

    // Enhanced Ruling Planets
    var rulingPlanets = getEnhancedRulingPlanets(positions, lagna, chartData, cusps, lagnaRi);

    // Common planets: house sigs that are also ruling planets, maintain L1>L2>L3>L4 order
    var commonPlanets = [];
    houseSigsFull.forEach(function(hs){
      // Expand Rahu/Ketu
      var expanded = expandRahuKetu(hs.pl);
      expanded.forEach(function(ep){
        if(rulingPlanets.indexOf(ep)!==-1){
          if(!commonPlanets.find(function(c){return c.pl===hs.pl;})){
            commonPlanets.push({pl:hs.pl, layer:hs.layer});
          }
        }
      });
    });

    // Dasa sequence and years
    var DASA_SEQ=[8,5,0,1,2,7,4,6,3];
    var DASA_YRS=[7,20,6,10,7,18,16,19,17];
    var TOTAL=120;
    var inp=chartData.input;
    var isKP249 = chartData.mode === "kp249";

    // For KP249: no birth details, use Gochara Moon for dasa calculation
    // moonPos from current chart positions (gochara moon when in kp249 mode)
    var moonPos=positions[1];
    var ni=moonPos.ni;
    var frac_elapsed = (moonPos.sidDeg*60 - ni*800) / 800;
    var dasaPl=NK[ni][2];
    var dasaSeqIdx=DASA_SEQ.indexOf(dasaPl);

    // For KP249: birthYr = today (gochara moon dasa starts from now)
    // For birth/gochara: birthYr = actual birth year
    var todayYr=new Date().getFullYear()+(new Date().getMonth())/12+(new Date().getDate())/365.25;
    var birthYr = isKP249
      ? todayYr
      : inp.year+(inp.month-1)/12+(inp.day-1)/365.25+(inp.utHr/24)/365.25;
    var dasaStartYr = isKP249
      ? todayYr - frac_elapsed * DASA_YRS[dasaSeqIdx]
      : birthYr - frac_elapsed * DASA_YRS[dasaSeqIdx];

    function yrToDate(yr){
      var y=Math.floor(yr);
      var rem=(yr-y)*365.25;
      var mo=Math.floor(rem/30.44)+1;
      var dy=Math.floor(rem%30.44)+1;
      if(mo>12)mo=12; if(dy>28)dy=28;
      return String(dy).padStart(2,'0')+"-"+String(mo).padStart(2,'0')+"-"+y;
    }

    // Workers in priority order (L1 first)
    var workers = commonPlanets.length > 0
      ? commonPlanets.map(function(c){return c.pl;})
      : houseSigsFull.map(function(c){return c.pl;}); // fallback

    // Deduplicate workers maintaining order
    var seenW=new Set(), uniqueWorkers=[];
    workers.forEach(function(p){if(!seenW.has(p)){seenW.add(p);uniqueWorkers.push(p);}});
    workers = uniqueWorkers;
    var wLen = workers.length;

    // Generate timing windows
    var windows = [];
    var pastWindows = [];

    // Walk dasa timeline
    var dasaTimeline=[];
    var dsScan=dasaStartYr;
    for(var si=0;si<72;si++){
      var siIdx=(dasaSeqIdx+si)%9, siPl=DASA_SEQ[siIdx], siYrs=DASA_YRS[siIdx];
      dasaTimeline.push({pl:siPl,start:dsScan,yrs:siYrs});
      dsScan+=siYrs;
      if(dsScan>todayYr+80) break;
    }

    // Find first dasa that starts at or after birth year
    var startDi=0;
    for(var ti=0;ti<dasaTimeline.length;ti++){
      if(dasaTimeline[ti].start+dasaTimeline[ti].yrs>birthYr){startDi=ti;break;}
    }

    // Cycle workers as Dasa->Bhukti->Antaram
    // CRITICAL: bStart must advance for ALL 9 bhuktis to keep dates correct
    // Past windows only shown if they start AFTER birthYr (person was alive)
    for(var di=startDi;di<dasaTimeline.length&&(windows.length<12||pastWindows.length<3);di++){
      var dt=dasaTimeline[di];
      if(workers.indexOf(dt.pl)===-1) continue;
      var bSeqStart=DASA_SEQ.indexOf(dt.pl);
      var bStart=dt.start;
      for(var b0=0;b0<9;b0++){
        var bPl=DASA_SEQ[(bSeqStart+b0)%9];
        var bSeqI=DASA_SEQ.indexOf(bPl);
        var bDur=dt.yrs*(DASA_YRS[bSeqI]/TOTAL);
        var bEnd=bStart+bDur; // compute bEnd for ALL bhuktis
        if(workers.indexOf(bPl)!==-1){
          var aSeqStart=DASA_SEQ.indexOf(bPl);
          var aStart=bStart;
          for(var a0=0;a0<9;a0++){
            var aPl=DASA_SEQ[(aSeqStart+a0)%9];
            var aSeqI=DASA_SEQ.indexOf(aPl);
            var aDur=bDur*(DASA_YRS[aSeqI]/TOTAL);
            var aEnd=aStart+aDur;
            // Only show if: worker planet AND antaram starts after birthYr
            if(workers.indexOf(aPl)!==-1 && aStart>=birthYr){
              var sunScanStart = Math.max(aStart, todayYr - 0.1);
              var commonPls = commonPlanets.map(function(cp){return cp.pl;});
              var sunTriggers = (aEnd >= todayYr - 1)
                ? findSunTriggers(sunScanStart, aEnd, commonPls)
                : [];
              var win={
                dasa:dt.pl, bhukti:bPl, antaram:aPl,
                start:aStart, end:aEnd,
                past: aEnd < todayYr,
                current: aStart<=todayYr && aEnd>=todayYr,
                layer: commonPlanets.find(function(c){return c.pl===dt.pl;})?
                  commonPlanets.find(function(c){return c.pl===dt.pl;}).layer : 4,
                sunTriggers: sunTriggers
              };
              if(aEnd < todayYr){
                // Only add past window if it starts after birth (person was alive)
                if(aStart >= birthYr && pastWindows.length<3) pastWindows.push(win);
              } else {
                if(windows.length<12) windows.push(win);
              }
            }
            aStart+=aDur;
          }
        }
        bStart=bEnd; // advance bStart using computed bEnd for ALL bhuktis
      }
    }

    // Rasi legs for jobs/children
    var cslLegsCount = RASI_LEGS[cslRi];
    var isInfertile = INFERTILE_RASI.indexOf(cslRi) !== -1;

    setResult({
      topic, hasPromise,
      // Step 1
      csl, cslStarLord, cslSubLord,
      // Condition 1
      starLordPlanets, cslStarSigs, promiseHit,
      // Condition 2
      cslRi, cslRasi, cslElem, cslType, cslGender, cslCaste, cslDharma,
      cslLegsCount, isInfertile,
      cslAllPlanets, cslSigs, cslInfluences,
      // Condition 3
      cslSubSigs, afterLoveAvg, afterMatAvg, afterOutcome,
      // Timing
      houseSigsFull, rulingPlanets, commonPlanets, workers,
      windows, pastWindows, yrToDate,
      todayYr, isKP249
    });
  }


