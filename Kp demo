        ce("button",{onClick:function(){lookup(num);},
          style:{padding:"8px 16px",background:"#1a1428",border:"1px solid "+C.purple,
            borderRadius:"6px",color:C.purple,cursor:"pointer",fontWeight:700}},
          isTA?"தேடு":"Go"),
        ce("button",{onClick:randomPick,
          style:{padding:"8px 14px",background:"#0a1828",border:"1px solid "+C.cyan,
            borderRadius:"6px",color:C.cyan,cursor:"pointer",fontWeight:700,fontSize:"12px"}},
          isTA?"சீரற்ற":"Random")
      ),
      !res&&num&&parseInt(num)&&ce("div",{style:{color:C.red,fontSize:"12px",marginTop:"6px"}},
        isTA?"தவறான எண் (1-249)":"Invalid number (1-249)")
    ),

    // KP Number info bar
    res&&ce("div",{style:{background:"#0e0e22",border:"1px solid #252545",borderRadius:"10px",
      padding:"10px 14px",marginBottom:"10px",display:"flex",gap:"12px",alignItems:"center",flexWrap:"wrap"}},
      ce("div",{style:{background:C.purple+"22",border:"1px solid "+C.purple+"88",borderRadius:"8px",
        padding:"6px 14px",textAlign:"center",minWidth:"60px"}},
        ce("div",{style:{fontSize:"9px",color:C.grey}},isTA?"KP எண்":"KP No."),
        ce("div",{style:{fontSize:"22px",fontWeight:900,color:C.purple}},res.n)
      ),
      ce("div",{style:{flex:1,display:"grid",gridTemplateColumns:"repeat(3,1fr)",gap:"8px"}},
        [{lbl:isTA?"ராசி (லக்னம்)":"Sign (Lagna)", val:isTA?RS_TA[res.entry.sg]:RS_EN[res.entry.sg], color:"#c8962a"},
         {lbl:isTA?"நட்சத்திரம்":"Star",           val:isTA?NK_TA[res.entry.nk]:NK_EN[res.entry.nk], color:"#4488ee"},
         {lbl:isTA?"உப அதிபதி":"Sub Lord",         val:isTA?PL_TA[res.entry.subl]:PL_EN[res.entry.subl], color:PL_CLR[res.entry.subl]}
