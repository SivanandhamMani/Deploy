function encodeChart(input) {
  try {
    var data = {
      n: input.name||"",
      g: input.gender||"male",
      d: input.day, mo: input.month, y: input.year,
      h: input.hour, mi: input.minute, s: input.second||0,
      la: input.lat, lo: input.lon,
      p: input.place||""
    };
    return btoa(unescape(encodeURIComponent(JSON.stringify(data))));
  } catch(e) { return ""; }
}

function decodeChart(hash) {
  try {
    var raw = hash.replace(/^#/,"");
    if (!raw || raw.length < 10) return null;
    var data = JSON.parse(decodeURIComponent(escape(atob(raw))));
    if (!data.y || !data.d || !data.mo) return null;
    var istHr = (data.h||0) + (data.mi||0)/60 + (data.s||0)/3600;
    return {
      name: data.n||"", gender: data.g||"male",
      day: data.d, month: data.mo, year: data.y,
      hour: data.h||0, minute: data.mi||0, second: data.s||0,
      utHr: istHr - 5.5,
      lat: data.la||13.0827, lon: data.lo||80.2707,
      place: data.p||""
    };
  } catch(e) { return null; }
}


