function earthHelio(T) {
  const e = 0.01670862 - 0.000042037*T;
  const L = norm(100.464457 + 35999.372476*T);
  const w = norm(102.937348 + 0.322503*T);
  const M = norm(L - w);
  const Mr = toRad(M);
  const E = M + toDeg(e*Math.sin(Mr) + e*e/2*Math.sin(2*Mr));
  const Er = toRad(E);
  const v = norm(2*toDeg(Math.atan2(Math.sqrt(1+e)*Math.sin(Er/2), Math.sqrt(1-e)*Math.cos(Er/2))));
  const Lh = norm(v + w);
  const rr = (1.000001018*(1-e*e))/(1+e*Math.cos(toRad(v)));
  return { x: rr*Math.cos(toRad(Lh)), y: rr*Math.sin(toRad(Lh)) };
}

function planetHelio(a0,e0,de,L0,dL,w0,dw,T) {
  const e = e0+de*T, L = norm(L0+dL*T), w = norm(w0+dw*T), M = norm(L-w);
  const Mr = toRad(M);
  const E = M + toDeg(e*Math.sin(Mr)+e*e/2*Math.sin(2*Mr)+e*e*e/8*(3*Math.sin(3*Mr)-Math.sin(Mr)));
  const Er = toRad(E);
  const v = norm(2*toDeg(Math.atan2(Math.sqrt(1+e)*Math.sin(Er/2), Math.sqrt(1-e)*Math.cos(Er/2))));
  const Lh = norm(v+w);
  const rr = (a0*(1-e*e))/(1+e*Math.cos(toRad(v)));
  return { x: rr*Math.cos(toRad(Lh)), y: rr*Math.sin(toRad(Lh)) };
}

