function calcDasaBalance(moonPos) {
  var ni = moonPos.ni;
  var mn = moonPos.sidDeg*60 - ni*800;
  var frac = 1 - mn/800;
  var yrs = DASA[NK[ni][2]] * frac;
  var y = Math.floor(yrs), mRem = (yrs-y)*12, m = Math.floor(mRem), d = Math.round((mRem-m)*30);
  return { planet: NK[ni][2], years:y, months:m, days:d };
}

function calcSignificators(positions, lagna) {
  var kpPositions = positions.filter(function(p){ return p.pl <= 8; });
  var plHouse = {};
  kpPositions.forEach(function(p) {
    plHouse[p.pl] = ((p.ri - lagna.ri + 12) % 12) + 1;
  });
  return kpPositions.map(function(p) {
    var hp   = ((p.ri - lagna.ri + 12) % 12) + 1;
    var nlHp = plHouse[p.nl] !== undefined ? [plHouse[p.nl]] : [];
    var owned = RS_LORD.map(function(l,i) { return l===p.pl ? ((i-lagna.ri+12)%12)+1 : null; }).filter(Boolean);
    var nlH   = RS_LORD.map(function(l,i) { return l===p.nl ? ((i-lagna.ri+12)%12)+1 : null; }).filter(Boolean);
    var all   = Array.from(new Set(nlHp.concat([hp]).concat(owned).concat(nlH))).sort(function(a,b){return a-b;});
    return { pl:p.pl, hp:hp, nlHp:nlHp, owned:owned, nlH:nlH, all:all };
  });
}

