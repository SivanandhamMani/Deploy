// Planet aspects: returns array of absolute degrees aspected by planet at given degree
function getPlanetAspects(pl, deg) {
  // pl: 0=Sun,1=Moon,2=Mars,3=Mercury,4=Jupiter,5=Venus,6=Saturn,7=Rahu,8=Ketu
  // Sun,Moon,Mercury,Venus: 7th only
  // Mars: 4th,7th,8th
  // Jupiter: 5th,7th,9th
  // Saturn: 3rd,7th,10th
  // Rahu,Ketu: NO vision/aspect
  if (pl === 7 || pl === 8) return []; // Rahu/Ketu have no aspect/vision
  var aspects = [180]; // 7th aspect for all other planets
  if (pl === 2) aspects = aspects.concat([90, 210]);   // Mars: +4th(90),+8th(210)
  if (pl === 4) aspects = aspects.concat([120, 240]);  // Jupiter: +5th(120),+9th(240)
  if (pl === 6) aspects = aspects.concat([60, 270]);   // Saturn: +3rd(60),+10th(270)
  return aspects.map(function(a){ return (deg + a) % 360; });
}

// Check if two degrees are within +-15 orb
function withinOrb(d1, d2) {
  var diff = Math.abs(d1 - d2) % 360;
  if (diff > 180) diff = 360 - diff;
  return diff <= 15;
}

