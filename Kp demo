function KPNumGrid(props) {
  var kpLagna   = props.lagna;
  var kpCusps   = props.cusps;
  var kpTPosns  = props.tpositions || [];
  var kpIsTA    = props.lang === "ta";
  var kpSelNum  = props.selNum;
  var kpSh      = function(i){ return kpIsTA ? PL_STA[i] : PL_SEN[i]; };
  var BCLR      = "1px solid #2a2a4a";
  var CH_PX     = 150;
  var FLAT      = [11,0,1,2, 10,-1,-1,3, 9,-1,-1,4, 8,7,6,5];

  function kpFmt(deg) {
    var s = deg % 30;
    var D = Math.floor(s);
    var M = Math.floor((s-D)*60);
    var S = Math.floor(((s-D)*60 - M)*60);
    return D + "." + String(M).padStart(2,"0") + "." + String(S).padStart(2,"0");
  }

  // Cusp map: rasi -> cusps
  var kpCM = {};
  for (var kci = 0; kci < kpCusps.length; kci++) {
    var kcc = kpCusps[kci];
    if (!kpCM[kcc.ri]) kpCM[kcc.ri] = [];
    kpCM[kcc.ri].push(kcc);
  }

  // Transit planet map: rasi -> planets
  var kpPM = {};
  for (var kpi = 0; kpi < kpTPosns.length; kpi++) {
    var kpp = kpTPosns[kpi];
    if (!kpPM[kpp.ri]) kpPM[kpp.ri] = [];
    kpPM[kpp.ri].push({
      lbl: kpSh(kpp.pl),
      deg: kpp.sidDeg,
      nl:  kpSh(kpp.nl),
      sub: kpSh(kpp.subl),
      clr: PL_CLR[kpp.pl]
    });
  }

  var kpLagRi = kpLagna.ri;

  var cells = [];
  for (var krow = 0; krow < 4; krow++) {
    for (var kcol = 0; kcol < 4; kcol++) {
      var krasi = FLAT[krow * 4 + kcol];
      var kIsCenter = (krasi === -1);
      if (kIsCenter && !(krow === 1 && kcol === 1)) continue;
      var kBR = kcol < 3 ? BCLR : "none";
      var kBB = krow < 3 ? BCLR : "none";

      if (kIsCenter) {
        cells.push(ce("div", {key:"center", style:{
          gridColumn:"2 / 4", gridRow:"2 / 4", background:"#0a0a1a",
          borderRight:BCLR, borderBottom:"none", borderLeft:"none", borderTop:"none",
          display:"flex", flexDirection:"column", alignItems:"center",
          justifyContent:"center", padding:"6px"
        }},
          ce("div", {style:{color:"#cc88ff",fontSize:"11px",fontWeight:800,textAlign:"center"}},
            "KP Lookup"),
          ce("div", {style:{color:"#44ff88",fontSize:"9px",textAlign:"center",marginTop:"3px"}},
            kpIsTA ? "லக்னம்" : "Lagna"),
          ce("div", {style:{color:"#e8b84a",fontSize:"9px",textAlign:"center",marginTop:"2px"}},
            kpIsTA ? RS_TA[kpLagRi] : RS_EN[kpLagRi]),
          ce("div", {style:{color:"#cc88ff",fontSize:"14px",fontWeight:900,textAlign:"center",marginTop:"4px"}},
            "KP#" + kpSelNum)
        ));
      } else {
        var kCellCu = kpCM[krasi] || [];
        var kCellPl = kpPM[krasi] || [];
        var kIsLag  = krasi === kpLagRi;

        cells.push(ce("div", {key: krow+"-"+kcol, style:{
          height: CH_PX+"px", borderRight:kBR, borderBottom:kBB,
          borderLeft:"none", borderTop:"none",
          background: kIsLag ? "#0d1a10" : "#111128",
          position:"relative", overflow:"hidden",
          boxSizing:"border-box", padding:"2px 3px"
        }},
          ce("div", {style:{fontSize:"8px", color: kIsLag?"#44ff88":"#484868",
            fontFamily:"monospace", fontWeight:700, lineHeight:1}},
            kpIsTA ? RS_TA[krasi].substring(0,3) : RS_SH[krasi]),
          kIsLag && ce("div", {style:{position:"absolute",top:"2px",right:"3px",
            fontSize:"8px",color:"#44ff88",fontWeight:700}},
            kpIsTA ? "லக்" : "Lag"),
          ce("div", {style:{marginTop:"2px"}},
            kCellCu.map(function(hc, hci) {
              return ce("div", {key:hci, style:{fontSize:"9px",color:"#585878",
                fontFamily:"monospace",lineHeight:1.4}},
                toRoman(hc.house) + " " + fmtSign(hc.d)
              );
            })
          ),
          kCellPl.length > 0 && ce("div", {style:{
            borderTop:"1px solid #252545", marginTop:"3px", paddingTop:"2px"
          }},
            kCellPl.map(function(pp, ppi) {
              return ce("div", {key:ppi, style:{marginBottom:"1px"}},
                ce("div", {style:{display:"flex",gap:"3px",alignItems:"baseline",lineHeight:1.3}},
                  ce("span", {style:{color:pp.clr,fontWeight:700,fontSize:"11px",
                    fontFamily:"monospace",minWidth:"18px"}}, pp.lbl),
                  pp.nl  && ce("span", {style:{color:"#4488ee",fontSize:"9px",fontFamily:"monospace"}}, pp.nl),
                  pp.sub && ce("span", {style:{color:"#ffaa44",fontSize:"9px",fontFamily:"monospace"}}, pp.sub)
                ),
                ce("div", {style:{color:"#e8b84a",fontSize:"9px",fontFamily:"monospace",
                  lineHeight:1.2,paddingLeft:"2px"}}, kpFmt(pp.deg))
              );
            })
          )
        ));
      }
    }
  }

  return ce("div", {style:{
    display:"grid",
    gridTemplateColumns:"25% 25% 25% 25%",
    gridTemplateRows: CH_PX+"px "+CH_PX+"px "+CH_PX+"px "+CH_PX+"px",
    width:"100%", border:"2px solid #cc88ff", borderRadius:"4px",
    overflow:"hidden", background:"#0a0a1a",
    boxShadow:"0 4px 20px rgba(0,0,0,.7)", boxSizing:"border-box"
  }}, cells);
}







