// Sun trigger: scan a period day by day, find dates where
// Sun rasi lord AND Sun nakshatra star lord are BOTH common planets
// Returns array of trigger dates (as year floats), max 2
function findSunTriggers(startYr, endYr, commonPls) {
  if(commonPls.length === 0) return [];
  var triggers = [];
  // Step: every 5 days (Sun moves ~5 deg, stays in nakshatra ~13 days)
  var step = 5/365.25;
  var prev_rasi_lord = -1, prev_star_lord = -1;
  for(var yr = startYr; yr <= endYr && triggers.length < 2; yr += step) {
    // Convert year to JD
    var y = Math.floor(yr);
    var rem = (yr - y) * 365.25;
    var mo = Math.floor(rem / 30.44) + 1;
    var dy = Math.floor(rem % 30.44) + 1;
    if(mo > 12) mo = 12; if(dy > 28) dy = 28;
    var utHr = (rem % 1) * 24;
    var T = (julianDay(y, mo, dy, utHr) - 2451545.0) / 36525.0;
    var ayan = lahiriAyanamsa(T);
    var sunTrop = calcSun(T);
    var sunSid = norm(sunTrop - ayan);
    // Sun rasi and nakshatra
    var sunRi = Math.floor(sunSid / 30);
    var sunNi = Math.floor(sunSid / (800/60));
    var sunRasiLord = RS_LORD[sunRi];
    var sunStarLord = NK[sunNi][2];
    // Both must be common planets
    var rasiMatch = commonPls.indexOf(sunRasiLord) !== -1;
    var starMatch = commonPls.indexOf(sunStarLord) !== -1;
    // Detect transition into a new matching zone (avoid duplicates)
    var newZone = (sunRasiLord !== prev_rasi_lord || sunStarLord !== prev_star_lord);
    if(rasiMatch && starMatch && newZone) {
      triggers.push(yr);
    }
    prev_rasi_lord = sunRasiLord;
    prev_star_lord = sunStarLord;
  }
  return triggers;
}

